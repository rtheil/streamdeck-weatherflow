{
  "compilerOptions": {
    "declaration": false,
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": "./src",
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
